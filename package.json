{
  "name": "edu-canvas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "imports": {
    "#/*": "./src/*",
    "@/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write package.json components.json tsconfig.json tsr.config.json vite.config.ts eslint.config.js prettier.config.js vitest.config.ts src scripts migrations README.md docs/foundation-runbook.md docs/architecture-harness.md",
    "format:check": "prettier --check package.json components.json tsconfig.json tsr.config.json vite.config.ts eslint.config.js prettier.config.js vitest.config.ts src scripts migrations README.md docs/foundation-runbook.md docs/architecture-harness.md",
    "typecheck": "tsc --noEmit",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm verify:client-boundary && pnpm verify:architecture",
    "db:migrate": "node --import tsx scripts/db-migrate.ts",
    "db:seed": "node --import tsx scripts/db-seed.ts",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "verify:client-boundary": "node --import tsx scripts/verify-client-boundary.ts",
    "verify:architecture": "node --import tsx scripts/verify-architecture.ts",
    "verify:config": "node --import tsx scripts/verify-config.ts",
    "smoke": "node --import tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/react-router": "1.170.18",
    "@tanstack/react-start": "1.168.28",
    "@tanstack/router-plugin": "1.168.20",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.24.0",
    "nitro": "3.0.260610-beta",
    "postgres": "3.4.9",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "0.4.0",
    "@tanstack/router-cli": "1.167.19",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "shadcn": "4.13.0",
    "tsx": "4.23.1",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
